# =========================
# SECRET FILES - DO NOT PUSH
# =========================
**/.env
**/.env.*
!**/.env.example
**/credentials.json
**/client_secret*.json
**/service-account*.json
**/*secret*.json
**/*token*.json
**/storage/app/google/*.json

# =========================
# LARAVEL
# =========================
**/vendor/
**/node_modules/
**/storage/logs/*.log
**/storage/framework/cache/*
**/storage/framework/sessions/*
**/storage/framework/views/*
**/bootstrap/cache/*.php
**/public/storage
**/.phpunit.result.cache

